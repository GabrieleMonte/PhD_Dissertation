\newlabel{sec:ch4-results_fits}{{4.5.2}{88}{Numerical fits of the scalar dissipation function $G(Q)$}{subsection.4.5.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5.2}Numerical fits of the scalar dissipation function $G(Q)$ }{88}{subsection.4.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces {\it  Upper panel:} The numerical solutions obtained with our code for the scalar dissipation function $G(Q)$ as a function of $Q$, along with an assessment of the goodness of the fitting functions in eqs.~\eqref  {eq:ch4-GQ_pol} and \eqref  {eq:ch4-GQ_log} with the fitting parameters reported in the caption. We have considered a monomial potential, see eq.~\eqref  {eq:ch4-monomial_potential}, with $n = 4$ and $\mitlambda = 10^{-14}$. Results are shown for a different temperature dependence in the dissipation rate (see eq.~\eqref  {eq:ch4-Upsilon}): $c = 3$ (red), $c = 1$ (blue), $c = -1$ (green). {\it  Lower panel:} The fractional residuals between the numerical result and the two different choices of the fit for each value of $c$, over the range of the dissipation strength $Q$ considered.}}{88}{figure.caption.14}\protected@file@percent }
\newlabel{fig:ch4-GQ_fits}{{4.2}{88}{{\it Upper panel:} The numerical solutions obtained with our code for the scalar dissipation function $G(Q)$ as a function of $Q$, along with an assessment of the goodness of the fitting functions in eqs.~\eqref {eq:ch4-GQ_pol} and \eqref {eq:ch4-GQ_log} with the fitting parameters reported in the caption. We have considered a monomial potential, see eq.~\eqref {eq:ch4-monomial_potential}, with $n = 4$ and $\lambda = 10^{-14}$. Results are shown for a different temperature dependence in the dissipation rate (see eq.~\eqref {eq:ch4-Upsilon}): $c = 3$ (red), $c = 1$ (blue), $c = -1$ (green). {\it Lower panel:} The fractional residuals between the numerical result and the two different choices of the fit for each value of $c$, over the range of the dissipation strength $Q$ considered}{figure.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.1}{\ignorespaces The parameters obtained from the fitting functions in eqs.~\eqref  {eq:ch4-GQ_pol} and \eqref  {eq:ch4-GQ_log} to the numerical results for $G(Q)$ for shown in figure~\ref {fig:ch4-GQ_fits}.}}{89}{table.caption.15}\protected@file@percent }
\newlabel{tab:ch4-1}{{4.1}{89}{The parameters obtained from the fitting functions in eqs.~\eqref {eq:ch4-GQ_pol} and \eqref {eq:ch4-GQ_log} to the numerical results for $G(Q)$ for shown in figure~\ref {fig:ch4-GQ_fits}}{table.caption.15}{}}
