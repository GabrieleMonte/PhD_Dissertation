\citation{Berera:1998gx,Berera:1998px,Bastero-Gil:2012akf,Berghaus:2019whh}
\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces {\it  Upper panel:} An assessment of the impact of the index $m$ in Eq.~\eqref  {eq:ch4-Upsilon} on the numerical results of the scalar dissipation function $G(Q)$, for different temperature dependence in the dissipation rate, namely $c = 3$ (red), $c = -1$ (green). {\it  Lower panel:} The fractional residuals between the different choices of the index $m$ over the range of the dissipation strength $Q$ considered. In summary, this figure demonstrates that $G(Q)$ is independent on the value of $m$.}}{91}{figure.caption.16}\protected@file@percent }
\newlabel{fig:ch4-2}{{4.3}{91}{{\it Upper panel:} An assessment of the impact of the index $m$ in Eq.~\eqref {eq:ch4-Upsilon} on the numerical results of the scalar dissipation function $G(Q)$, for different temperature dependence in the dissipation rate, namely $c = 3$ (red), $c = -1$ (green). {\it Lower panel:} The fractional residuals between the different choices of the index $m$ over the range of the dissipation strength $Q$ considered. In summary, this figure demonstrates that $G(Q)$ is independent on the value of $m$}{figure.caption.16}{}}
